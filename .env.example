# FloodWatch production environment example
# Copy to .env for local private testing, or set these in your hosting provider.

SECRET_KEY=change-this-to-a-long-random-secret
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# Use the final public HTTPS URL after deployment.
# Example: https://floodwatch-demo.onrender.com
CORS_ORIGINS=https://your-public-domain.example

# Google Earth Engine project id.
GEE_PROJECT=flood-prediction-0325

# Risk thresholds are decimal probabilities:
# HIGH starts at 0.70 = 70%, MEDIUM starts at 0.40 = 40%.
RISK_THRESHOLD_HIGH=0.70
RISK_THRESHOLD_MEDIUM=0.40

# Email settings should be moved here for production.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=FloodWatch
DEFAULT_ALERT_EMAIL=admin@example.com
